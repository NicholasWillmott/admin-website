#!/bin/bash
set -e

START_TIME=$SECONDS

DROPLET="root@137.184.155.181"
REMOTE_DIR="/var/www/admin-website"

echo "==> Building frontend..."
npm run build

echo "==> Deploying frontend to droplet..."
rsync -az --delete dist/ "$DROPLET:$REMOTE_DIR/dist/"

read -rp "Commit message: " COMMIT_MSG
COMMIT_MSG="${COMMIT_MSG:-deploy}"

echo "==> Staging and committing changes..."
git add -A
git diff --cached --quiet || git commit -m "$COMMIT_MSG"

echo "==> Pushing backend changes..."
git push

echo "==> Syncing .env to droplet..."
rsync -az src/backend/.env "$DROPLET:$REMOTE_DIR/src/backend/.env"

echo "==> Pulling and restarting backend on droplet..."
ssh "$DROPLET" "cd $REMOTE_DIR && git pull && systemctl restart admin-backend"

DURATION=$((SECONDS - START_TIME))
DURATION_MIN=$((DURATION / 60))
DURATION_SEC=$((DURATION % 60))

TEAL='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${TEAL}╔══════════════════════════════════════════════════════════════════════╗"
echo -e "║                                                                      ║"
echo -e "║                      DEPLOYMENT SUCCESSFUL!                          ║"
echo -e "║                                                                      ║"
echo -e "╠══════════════════════════════════════════════════════════════════════╣"
echo -e "║  Operations Completed:                                               ║"
echo -e "║    - Frontend built successfully                                     ║"
echo -e "║    - Frontend deployed to droplet                                    ║"
echo -e "║    - Changes committed to Git                                        ║"
echo -e "║    - Changes pushed to remote repository                             ║"
echo -e "║    - .env synced to droplet                                          ║"
echo -e "║    - Backend pulled and restarted on droplet                         ║"
echo -e "║                                                                      ║"
printf "${TEAL}║  %-68s║\n" "Duration: ${DURATION_MIN} minutes ${DURATION_SEC} seconds"
echo -e "╚══════════════════════════════════════════════════════════════════════╝${NC}"
echo ""
